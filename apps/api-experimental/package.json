{
    "name": "altered-api-experimental",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "altered-sync-assets --watch & tsx watch --env-file=../../.env --include ../../.env src/index.ts",

        "check:types": "tsc",

        "clean": "altered-clean-package",

        "build": "altered-sync-assets && altered-validate-environment && altered-bundle-application",

        "start": "node dist/index.js"
    },
    "dependencies": {
        "@altered/api-experimental": "workspace:*",
        "hono": "catalog:"
    },
    "devDependencies": {
        "@altered/core-experimental": "workspace:*",
        "@altered/tooling": "workspace:*",
        "@types/node": "catalog:",
        "tsx": "catalog:",
        "typescript": "catalog:"
    }
}
