{
    "$schema": "https://turborepo.com/schema.json",
    "ui": "tui",

    "globalDependencies": [".env.*", ".env"],

    "tasks": {
        "//#tunnel": {
            "persistent": true,
            "cache": false,
            "env": ["API_PORT", "PROVIDER_NGROK_SECRET", "PROVIDER_NGROK_URL"]
        },

        "dev": {
            "persistent": true,
            "cache": false
        },

        "check:types": {
            "dependsOn": ["^check:types"]
        },
        "//#check:style": {},

        "//#fix:style": {
            "cache": false
        },

        "db:push": {
            "cache": false,
            "interactive": true
        },
        "db:studio": {
            "persistent": true,
            "cache": false
        },

        "build": {
            "dependsOn": ["^build"],
            "inputs": ["$TURBO_DEFAULT$"],
            "outputs": [".next/**", "!.next/cache/**"]
        }
    },

    "globalPassThroughEnv": [
        "NODE_ENV",
        "PORT",

        "VERCEL_ENV",
        "VERCEL_URL",
        "VERCEL_BRANCH_URL",
        "VERCEL_PROJECT_PRODUCTION_URL"
    ]
}
