{
    "name": "altered",
    "version": "0.1.0",
    "private": true,

    "scripts": {
        "tunnel": "pnpm dlx dotenv-cli -- sh -c 'exec pnpm dlx ngrok http \"$API_CONFIG_PORT\" --url \"$SHARED_PROVIDER_NGROK_URL\" --authtoken \"$SHARED_PROVIDER_NGROK_SECRET\"'",

        "dev": "turbo dev --filter=!*pre-release --filter=!*experimental --filter=!*internal*",
        "dev:experimental": "turbo dev --filter=*experimental",

        "check:types": "turbo check:types",
        "check:style": "ultracite check",
        "check": "turbo check:types check:style",
        "fix:style": "ultracite fix",
        "fix:style:force": "ultracite fix --unsafe",
        "fix": "turbo fix:style",

        "push:db": "turbo push:db",
        "view:db": "turbo view:db",

        "clean": "altered-clean-package -w",

        "build": "turbo build",

        "preview:promote": "altered-preview-promote --target '*'",
        "preview:promote:api-experimental": "altered-preview-promote --target api-experimental",

        "run:preview-generation-components": "tsx packages/server-experimental/scripts/preview-generation-components.ts",

        "run:run-agent": "tsx packages/server-experimental/scripts/run-agent.ts"
    },

    "devDependencies": {
        "@altered/tooling": "workspace:*",
        "@biomejs/biome": "^2.4.13",
        "tsx": "catalog:",
        "turbo": "^2.9.6",
        "ultracite": "^7.6.1"
    },

    "packageManager": "pnpm@11.8.0"
}
