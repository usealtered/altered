{
    "name": "altered",
    "version": "0.1.0",
    "private": true,

    "scripts": {
        "tunnel": "pnpm dlx dotenv-cli -- sh -c 'exec pnpm dlx ngrok http \"$API_CONFIG_PORT\" --url \"$SHARED_PROVIDER_NGROK_URL\" --authtoken \"$SHARED_PROVIDER_NGROK_SECRET\"'",

        "dev": "turbo dev --filter=!*pre-release --filter=!*experimental --filter=!*internal*",
        "dev:experimental": "turbo dev --filter=*experimental",

        "check:types": "turbo check:types",
        "check:style": "ultracite check",
        "check": "turbo check:types check:style",
        "fix:style": "ultracite fix",
        "fix:style:force": "ultracite fix --unsafe",
        "fix": "turbo fix:style",

        "push:db": "turbo push:db",
        "view:db": "turbo view:db",

        "clean": "turbo clean && git clean -xdf .cache .turbo dist node_modules",

        "build": "turbo build"
    },

    "devDependencies": {
        "@biomejs/biome": "^2.4.13",
        "turbo": "^2.9.6",
        "ultracite": "^7.6.1"
    },

    "packageManager": "pnpm@10.20.0"
}
