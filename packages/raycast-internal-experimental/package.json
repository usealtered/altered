{
    "name": "@altered/raycast-internal-experimental",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "exports": {
        ".": {
            "types": "./src/index.ts",
            "bundler": "./src/index.ts",
            "import": "./dist/index.js"
        },
        "./*": {
            "types": "./src/*.ts",
            "bundler": "./src/*.ts",
            "import": "./dist/*.js"
        }
    },
    "scripts": {
        "dev": "tsc -p tsconfig.build.json --watch",

        "check:types": "tsc",

        "clean": "altered-clean-package",

        "build": "tsc -p tsconfig.build.json"
    },
    "dependencies": {
        "@altered/core-experimental": "workspace:*",
        "@raycast/api": "catalog:raycast"
    },
    "devDependencies": {
        "@altered/tooling": "workspace:*",
        "@types/node": "catalog:raycast",
        "typescript": "catalog:"
    }
}
