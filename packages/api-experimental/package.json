{
    "name": "@altered/api-experimental",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "exports": {
        ".": {
            "types": "./src/index.ts",
            "default": "./dist/index.js"
        },
        "./*": {
            "types": "./src/*.ts",
            "default": "./dist/*.js"
        }
    },
    "scripts": {
        "dev": "tsc --noEmit false --watch",

        "check:types": "tsc",

        "clean": "git clean -xdf .cache .turbo dist node_modules",

        "build": "tsc --noEmit false"
    },
    "dependencies": {
        "@altered/core-experimental": "workspace:*",
        "@altered/server-experimental": "workspace:*",
        "@hono/node-server": "catalog:",
        "@vercel/functions": "catalog:",
        "hono": "catalog:"
    },
    "devDependencies": {
        "@types/node": "catalog:",
        "typescript": "catalog:"
    }
}
