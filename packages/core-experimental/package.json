{
    "name": "@altered/core-experimental",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "exports": {
        "./*": {
            "types": "./src/*.ts",
            "bundler": "./src/*.ts",
            "default": "./dist/*.js"
        }
